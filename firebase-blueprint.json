{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Jewelry product information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "whatsappOrdered": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Store configuration",
      "type": "object",
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "upiId": { "type": "string" },
        "minOrderAmount": { "type": "number" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of products"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "settings": {
      "schema": "Setting",
      "description": "Store settings (doc id 'store')"
    }
  }
}
