{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Jewelry product information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "whatsappOrdered": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Store configuration",
      "type": "object",
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "upiId": { "type": "string" },
        "upiPhone": { "type": "string" },
        "upiQrImage": { "type": "string" },
        "upiText": { "type": "string" },
        "adminPath": { "type": "string" },
        "maxImageSize": { "type": "number" },
        "minOrderAmount": { "type": "number" },
        "cities": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "charge": { "type": "number" }
            }
          }
        }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": {
          "type": "object",
          "properties": {
            "flat": { "type": "string" },
            "apartment": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "pincode": { "type": "string" },
            "googleMapsLink": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of products"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "settings": {
      "schema": "Setting",
      "description": "Store settings (doc id 'store')"
    },
    "users": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
