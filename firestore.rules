rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'itssanjaydutta@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isStaff() {
      return isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price > 0 &&
             data.category is string &&
             data.stock is number && data.stock >= 0 &&
             (!data.keys().contains('images') || data.images is list) &&
             (!data.keys().contains('description') || data.description is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerInfo', 'items', 'totalAmount']) &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.customerInfo is map &&
             data.items is list &&
             data.createdAt == request.time;
    }

    function isValidSetting(data) {
      return data.keys().hasAll(['categories', 'upiId', 'minOrderAmount']) &&
             data.categories is list &&
             data.upiId is string &&
             data.minOrderAmount is number;
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isStaff() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isStaff() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'stock', 'images', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming()) && isValidId(orderId);
      allow read, list: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && settingId == 'store' && isValidSetting(incoming());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }
  }
}
